{
  "name": "wafflerace",
  "private": true,
  "scripts": {
    "build:css": "tailwindcss -i ./web/input.css -o ./web/static/css/app.css --minify",
    "watch:css": "tailwindcss -i ./web/input.css -o ./web/static/css/app.css --watch",
    "lint": "eslint web/static/js --ext .js",
    "lint:fix": "eslint web/static/js --ext .js --fix",
    "format": "prettier --write \"web/static/js/**/*.js\"",
    "test": "vitest run",
    "test:watch": "vitest",
    "test:e2e": "playwright test",
    "test:e2e:ui": "playwright test --ui",
    "convert:webp": "node scripts/convert-to-webp.js",
    "convert:boats": "node scripts/convert-to-webp.js assets/boat-sprites --quality 85",
    "convert:backgrounds": "node scripts/convert-to-webp.js assets/backgrounds --quality 88",
    "convert:collection": "node scripts/convert-to-webp.js"
  },
  "devDependencies": {
    "@playwright/test": "^1.60.0",
    "daisyui": "^4.12.23",
    "eslint": "^8.57.0",
    "jsdom": "^24.1.0",
    "prettier": "^3.3.3",
    "tailwindcss": "^3.4.17",
    "vitest": "^1.6.0"
  }
}
